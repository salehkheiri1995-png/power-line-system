# نمونه متغیرهای محیطی برای power-line-system
# این فایل را کپی کرده و با نام .env ذخیره کنید
# مقادیر واقعی را در .env تنظیم کنید (هرگز .env را کامیت نکنید)

# کلید رمزنگاری JWT - حتماً یک مقدار تصادفی امن تعیین کنید
# برای ساخت: python -c "import secrets; print(secrets.token_hex(32))"
POWER_LINE_SECRET_KEY=change_this_to_a_random_64char_hex_string

# آدرس دیتابیس
POWER_LINE_DATABASE_URL=sqlite:///./power_line.db

# پسورد کاربر ادمین پیش‌فرض (فقط اولین بار استفاده می‌شود)
POWER_LINE_ADMIN_PASSWORD=change_this_strong_password

# دامنه‌های مجاز برای CORS (با کاما جدا کنید)
# مثال: http://localhost:5173,https://yourapp.example.com
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
